<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CC0A0A0A"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#44FFD700"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>